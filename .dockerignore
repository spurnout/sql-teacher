# Dependencies (reinstalled inside Docker)
node_modules

# Next.js build output (rebuilt inside Docker)
.next
out

# Env files — credentials must come from docker-compose environment, not baked in
.env
.env.local
.env.*.local
.env.production

# Dev tooling (not needed in image)
.claude
.git
.gitignore

# Import files (mounted at runtime via docker-compose volume, not baked into image)
imports

# Misc
.DS_Store
*.pem
npm-debug.log*
yarn-debug.log*
.pnpm-debug.log*
postgres_data
